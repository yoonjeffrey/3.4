{
  "info": {
    "name": "API Tareas MVC - Lab Practice",
    "schema": "https://schema.getpostman.com/json/collection/2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Obtener todas las tareas",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/tareas",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tareas"]
        }
      }
    },
    {
      "name": "Obtener todas (Texto Plano)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/tareas?formato=text",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tareas"],
          "query": [{ "key": "formato", "value": "text" }]
        }
      }
    },
    {
      "name": "Buscar tareas",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/tareas/buscar?q=express",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tareas", "buscar"],
          "query": [{ "key": "q", "value": "express" }]
        }
      }
    },
    {
      "name": "Obtener por ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/tareas/1",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tareas", "1"]
        }
      }
    },
    {
      "name": "Crear tarea",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"titulo\": \"Nueva Tarea de Prueba\",\n  \"completada\": false\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/api/tareas",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tareas"]
        }
      }
    },
    {
      "name": "Actualizar completa (PUT)",
      "request": {
        "method": "PUT",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"titulo\": \"Título Actualizado Completamente\",\n  \"completada\": true\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/api/tareas/1",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tareas", "1"]
        }
      }
    },
    {
      "name": "Actualizar parcial (PATCH)",
      "request": {
        "method": "PATCH",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"completada\": true\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/api/tareas/2",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tareas", "2"]
        }
      }
    },
    {
      "name": "Eliminar tarea",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/tareas/3",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tareas", "3"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    }
  ]
}
